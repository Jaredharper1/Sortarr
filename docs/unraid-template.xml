<?xml version="1.0"?>
<Container version="2">
  <Name>Sortarr</Name>

  <Repository>ghcr.io/jaredharper1/sortarr:latest</Repository>
  <Registry>https://github.com/jaredharper1/Sortarr/pkgs/container/sortarr</Registry>

  <Network>bridge</Network>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>

  <Support>https://github.com/jaredharper1/sortarr/issues</Support>
  <Project>https://github.com/jaredharper1/sortarr</Project>
  <TemplateURL>https://raw.githubusercontent.com/Jaredharper1/Sortarr/main/docs/unraid-template.xml</TemplateURL>

  <Overview>Sortarr is a read-only analytics and organisation dashboard for media libraries, with support for Sonarr, Radarr, Plex, Jellyfin, Tautulli, Jellystat, and Streamystats.</Overview>
  <Description>Read-only media library analytics for Arr, Plex, and Jellyfin with optional playback/history overlays and provider insights. Secrets are migrated to /config/secrets and plaintext secret fallback is disabled.</Description>

  <Category>MediaApp:Tools</Category>
  <WebUI>http://[IP]:[PORT:8787]/</WebUI>
  <Icon>https://raw.githubusercontent.com/Jaredharper1/Sortarr/main/static/Logo.png</Icon>

  <Config Name="WebUI Port"
          Target="8787"
          Default="9595"
          Mode="tcp"
          Description="Host port for accessing Sortarr WebUI. Container listens on 8787."
          Type="Port"
          Display="always"
          Required="true"
          Mask="false">9595</Config>

  <Config Name="Appdata"
          Target="/config"
          Default="/mnt/user/appdata/sortarr"
          Mode="rw"
          Type="Path"
          Display="always"
          Required="true"
          Mask="false">/mnt/user/appdata/sortarr</Config>

  <Config Name="PUID"
          Target="PUID"
          Default="99"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">99</Config>

  <Config Name="PGID"
          Target="PGID"
          Default="100"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">100</Config>

  <Config Name="ENV_FILE_PATH"
          Target="ENV_FILE_PATH"
          Default="/config/Sortarr.env"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">/config/Sortarr.env</Config>

  <Config Name="SORTARR_STORE_SECRETS_AS_FILES"
          Target="SORTARR_STORE_SECRETS_AS_FILES"
          Default="1"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">1</Config>

  <Config Name="SORTARR_ALLOW_PLAINTEXT_SECRETS"
          Target="SORTARR_ALLOW_PLAINTEXT_SECRETS"
          Default="0"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">0</Config>

  <Config Name="SORTARR_ALLOW_UNSAFE_EPHEMERAL_RECOVERY"
          Target="SORTARR_ALLOW_UNSAFE_EPHEMERAL_RECOVERY"
          Default="0"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">0</Config>

  <Config Name="SORTARR_PROXY_MODE"
          Target="SORTARR_PROXY_MODE"
          Default="direct"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">direct</Config>

  <Config Name="SORTARR_WAITRESS_TRUSTED_PROXY"
          Target="SORTARR_WAITRESS_TRUSTED_PROXY"
          Default=""
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false"></Config>

  <Config Name="SORTARR_PROXY_HOPS_PREFIX"
          Target="SORTARR_PROXY_HOPS_PREFIX"
          Default="0"
          Type="Variable"
          Display="advanced"
          Required="false"
          Mask="false">0</Config>
</Container>
