# Sortarr minimal supported surface
# Use one secret source per variable: VAR, VAR_FILE, or VAR_CRED_TARGET.

# Persistent session secret (recommended)
SORTARR_SECRET_KEY_FILE=/run/secrets/sortarr_secret_key
# Windows alternative:
# SORTARR_SECRET_KEY_CRED_TARGET=Sortarr/SORTARR_SECRET_KEY

# Proxy mode (preferred primary setting)
SORTARR_PROXY_MODE=single

# Media source path: Arr (default recommendation)
SONARR_URL=http://sonarr:8989
SONARR_API_KEY_FILE=/run/secrets/sonarr_api_key
RADARR_URL=http://radarr:7878
RADARR_API_KEY_FILE=/run/secrets/radarr_api_key

# OR media source path: Plex-only
# PLEX_URL=http://plex:32400
# PLEX_TOKEN_FILE=/run/secrets/plex_token

# Required auth
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS_FILE=/run/secrets/basic_auth_pass
# Windows alternative:
# BASIC_AUTH_PASS_CRED_TARGET=Sortarr/BASIC_AUTH_PASS

# Optional CSRF trusted-origin escape hatch (exact origins only):
# SORTARR_CSRF_TRUSTED_ORIGINS=https://sortarr.example.com

# Keep all other variables at defaults unless you need advanced behavior.
